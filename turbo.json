{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"with": ["backend#dev"]
		},
		"lint": {
			"outputs": []
		},
		"test": {
			"outputs": []
		}
	}
}
